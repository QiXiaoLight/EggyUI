<Window x:Class="EggyUISEInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EggyUI-SE 安装程序" 
        Height="450" 
        Width="600" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanMinimize"
        Cursor="">

	<!--
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="1"
                      ResizeBorderThickness="5"
                      CaptionHeight="34"/>
    </WindowChrome.WindowChrome>
	-->

    <Window.Background>
        <ImageBrush ImageSource="/Images/bg.png" 
                    Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <!-- 欢迎页 -->
        <Grid x:Name="WelcomePanel" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题区域 -->
            <StackPanel Grid.Row="0" Margin="20,30,20,20">
                <TextBlock Text="欢迎使用 EggyUI-RE 1.0 安装程序" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <TextBlock Text="你好，我的小蛋仔！" 
                           FontSize="14" 
                           Margin="0,0,0,5"/>
                <TextBlock Text="这个程序将引导你在这台电脑上完成 EggyUI-RE 蛋仔风美化包的安装。" 
                           FontSize="14"
                           TextWrapping="Wrap"/>
                <TextBlock Text="在这里选中你需要安装的美化组件，然后点击“安装”继续吧~" 
                           FontSize="14" 
                           Margin="0,5,0,0"/>
                <!-- 复选框列表：背景透明，不遮挡背景图 -->
                <StackPanel Margin="0,10,0,0" Background="Transparent">
                    <TextBlock Text="请选择要安装的组件：" FontSize="14" Margin="0,0,0,6"/>
                    <StackPanel Background="Transparent">
                        <CheckBox x:Name="ChkTheme" Content="主题" Background="Transparent" Margin="0,3,0,3"/>
                        <CheckBox x:Name="ChkIcons" Content="桌面图标" Background="Transparent" Margin="0,3,0,3"/>
                        <CheckBox x:Name="ChkFonts" Content="字体" Background="Transparent" Margin="0,3,0,3"/>
                        <CheckBox x:Name="ChkMouseCursors" Content="鼠标指针" Background="Transparent" Margin="0,3,0,3"/>
                        <CheckBox x:Name="ChkLockWallpaper" Content="锁屏壁纸" Background="Transparent" Margin="0,3,0,3"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" 
                        HorizontalAlignment="Center" 
                        Margin="20,20,20,30">
                <Button x:Name="StartInstallButton" 
                        Content="安装" 
                        Width="120" 
                        Height="35"
                        FontSize="14"
                        FontWeight="Bold" Click="StartInstallButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- 安装页 -->
        <Grid x:Name="InstallPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题区域 -->
            <StackPanel Grid.Row="0" Margin="20,30,20,20">
                <TextBlock Text="安装" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                <TextBlock Text="正在安装 EggyUI-SE 1.0" 
                           FontSize="14" 
                           Margin="0,0,0,5"/>
            </StackPanel>

            <!-- 状态信息区域 -->
            <StackPanel Grid.Row="1" 
                        VerticalAlignment="Top" 
                        Margin="20,0,20,0">
                <TextBlock x:Name="StatusText" 
                           Text="状态：" 
                           FontSize="13"/>
                <!-- 可选：添加进度条 -->
                <ProgressBar x:Name="InstallProgressBar" 
                             Height="10" 
                             Margin="0,20,0,0"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StackPanel>

            <!-- 底部占位，保持布局一致 -->
            <StackPanel Grid.Row="2" Height="50"/>
        </Grid>
    </Grid>
</Window>